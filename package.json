{
  "name": "univ-api-analytics",
  "version": "1.0.0",
  "description": "Drop-in API analytics middleware for Hono & Express with a built-in dashboard",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./hono": {
      "types": "./dist/middleware/hono.d.ts",
      "import": "./dist/middleware/hono.js"
    },
    "./express": {
      "types": "./dist/middleware/express.d.ts",
      "import": "./dist/middleware/express.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "analytics",
    "api",
    "hono",
    "express",
    "middleware",
    "dashboard",
    "monitoring"
  ],
  "author": "Zan Lah",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zanlah/univ-api-analytics.git"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.5.2",
    "hono": "^4.12.19",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "hono": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    },
    "express": {
      "optional": true
    }
  }
}
